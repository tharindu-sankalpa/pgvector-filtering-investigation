      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 77 },
      "id": 81,
      "title": "Pod Disk I/O",
      "description": "Disk read/write throughput. During retrieval, reads indicate cache misses. During inserts/index builds, high writes are expected.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(container_fs_reads_bytes_total{namespace=\"cnpg-pgvector\", pod=~\"ml-pgvector-benchmark-.*\", container!=\"\"}[5m]))", "legendFormat": "Disk Read" },
        { "expr": "sum(rate(container_fs_writes_bytes_total{namespace=\"cnpg-pgvector\", pod=~\"ml-pgvector-benchmark-.*\", container!=\"\"}[5m]))", "legendFormat": "Disk Write" }
