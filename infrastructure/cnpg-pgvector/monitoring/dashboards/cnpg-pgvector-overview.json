      "targets": [
        { "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"cnpg-pgvector\", pod=~\"ml-pgvector-benchmark-.*\"}[5m]))", "legendFormat": "RX (Queries In)" },
        { "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"cnpg-pgvector\", pod=~\"ml-pgvector-benchmark-.*\"}[5m]))", "legendFormat": "TX (Results Out)" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
