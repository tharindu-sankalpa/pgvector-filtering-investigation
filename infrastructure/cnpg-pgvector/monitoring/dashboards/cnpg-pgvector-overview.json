      "id": 71,
      "title": "Database Size Over Time",
      "description": "Total database disk usage. Tracks growth during insert benchmarks and steady state during retrieval.",
      "type": "timeseries",
      "targets": [
        { "expr": "cnpg_pg_database_size_bytes{datname=\"benchmark_vectors\"}", "legendFormat": "benchmark_vectors" },
        { "expr": "cnpg_collector_pg_wal{value=\"size\"}", "legendFormat": "WAL Directory" }
