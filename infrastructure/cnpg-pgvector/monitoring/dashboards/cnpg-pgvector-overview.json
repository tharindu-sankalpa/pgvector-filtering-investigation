      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 77 },
      "id": 80,
      "title": "Pod Network I/O",
      "description": "Network throughput to/from the PostgreSQL pod. During retrieval, RX = incoming queries, TX = result data. Compare with Milvus network patterns.",
